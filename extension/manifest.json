{
  "manifest_version": 3,
  "name": "Nexus Capture",
  "version": "1.0.0",
  "description": "Quick capture to your Nexus knowledge graph",
  "permissions": ["activeTab", "contextMenus"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
